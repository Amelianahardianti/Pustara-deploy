# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key

# Server Configuration
PORT=3000
NODE_ENV=neon
NEON_CLOUD_MODE=true

# Supabase Storage (used to resolve public PDF URLs from file_url paths)
SUPABASE_URL=https://your-project.supabase.co

# Database (required in neon mode)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# AI Service (optional, backend still starts if unreachable)
FASTAPI_URL=http://host.docker.internal:8001
CRON_SECRET=PUSTARAbrakadaba23

# SMTP (for lending reminders + digest emails)
SMTP_ENABLED=true
SMTP_FROM=no-reply@pustara.local
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Notes:
# 1. Copy this file to .env and fill in your actual values.
# 2. .env file is gitignored and should NEVER be committed.
# 3. Keep service account JSON files out of git as well.
